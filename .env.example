VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Custom portrait host (optional — overrides Supabase) ─────────────────────
# Set this to host images anywhere public.
# Images must be at: {VITE_PORTRAIT_BASE_URL}/{gender}/{class}/{level}.png
# Examples:
# VITE_PORTRAIT_BASE_URL=https://pub-abc123.r2.dev/portraits
# VITE_PORTRAIT_BASE_URL=https://yourname.github.io/quest-portraits
# VITE_PORTRAIT_BASE_URL=https://your-bucket.s3.amazonaws.com/portraits
